<?xml version="1.0" encoding="UTF-8"?>
<!-- Täglicher inkrementeller Wissens-Index-Refresh (3:00). Install analog health-check.plist. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
  <key>Label</key><string>de.alexheyers.murmel.indexrefresh</string>
  <key>ProgramArguments</key><array><string>/bin/bash</string><string>HOME_PLACEHOLDER/.murmel/index-refresh.sh</string></array>
  <key>StartCalendarInterval</key><dict><key>Hour</key><integer>3</integer><key>Minute</key><integer>0</integer></dict>
  <key>StandardOutPath</key><string>HOME_PLACEHOLDER/.murmel/index-refresh.log</string>
  <key>StandardErrorPath</key><string>HOME_PLACEHOLDER/.murmel/index-refresh.log</string>
</dict></plist>
